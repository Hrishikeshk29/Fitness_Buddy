# =============================================================================
# FITNESS BUDDY - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit your .env file to version control!

# -----------------------------------------------------------------------------
# IBM watsonx.ai Configuration
# -----------------------------------------------------------------------------
IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# -----------------------------------------------------------------------------
# IBM Granite Model (override if your environment supports a different model)
# -----------------------------------------------------------------------------
GRANITE_MODEL_ID=ibm/granite-4-h-small

# -----------------------------------------------------------------------------
# Flask Application Configuration
# -----------------------------------------------------------------------------
FLASK_SECRET_KEY=your_super_secret_flask_key_change_in_production
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///fitness_buddy.db

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Fitness Buddy
APP_VERSION=1.0.0
